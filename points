            "GuB": [1,6,15,15,20,19,19,16,17,14,10,16,17,18,17,18,19,19,16,15,13,11,11,11],
            "AnF": [1,6,9,10,5,7,7,5,7,6,13,10,3,5,3,9,8,8,3,5,10,7,10,12],
            "TW": [1,25,12,12,18,18,15,13,12,11,10,6,6,11,8,12,13,14,12,12,12,12,11,13],
            "LJ": [1,6,18,10,15,16,14,10,7,8,5,5,8,14,11,13,13,8,8,11,11,11,13,14],
            "PN": [1,6,9,4,3,5,4,4,4,6,6,10,12,17,14,15,15,15,13,13,13,13,14,15],
            "KO": [1,25,32,30,26,27,25,19,21,21,21,17,16,16,17,17,17,17,15,14,13,11,15,16],
            "CH": [1,25,14,11,18,18,23,18,19,20,20,19,19,23,24,24,24,24,23,23,22,22,16,17],
            "NV": [1,18,3,7,4,4,5,7,6,5,5,4,3,7,6,10,7,10,9,13,13,13,17,18],
