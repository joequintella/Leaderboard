            "AF": [1,5,15,15,14,14,14,21,21,23,26,28,29,33,35,35,35,35,35,35,35,35,35,35]
        };

        const traces = [];
        for (const [initials, ranks] of Object.entries(ranksData)) {
            traces.push({
                x: matchDays,
                y: ranks,
                type: 'scatter',
                mode: 'lines+markers',
                name: initials,
                marker: { size: 6 },
                line: { width: 2 },
                hovertemplate: `<b>${initials}</b><br>Match Day: %{x}<br>Place: %{y}<extra></extra>`
            });
        }

        const layout = {
            xaxis: {
                title: { text: 'Match Day', font: { weight: 'bold' } },
                gridcolor: '#EBF0F5',
                tickmode: 'array',
                tickvals: matchDays
            },
            yaxis: {
                title: { text: 'Leaderboard Position (Rank)', font: { weight: 'bold' } },
                gridcolor: '#EBF0F5',
                autorange: 'reversed', // This flips the Y-axis so 1st place is at the top!
                tickmode: 'linear',
                tick0: 1,
                dtick: 2
            },
            hovermode: 'closest',
            plot_bgcolor: '#ffffff',
            paper_bgcolor: '#ffffff',
            margin: { l: 60, r: 20, t: 20, b: 60 },
            legend: {
                title: { text: '<b>Initials</b>' },
                orientation: 'v',
                y: 0.5
            }
        };

        const config = { responsive: true };

        Plotly.newPlot('chart', traces, layout, config);
    </script>
</body>
</html>
