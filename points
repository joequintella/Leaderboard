import pandas as pd
import matplotlib.pyplot as plt

# 1. Load the dataset
df = pd.read_excel("Points per match.xlsx")

# 2. Reshape data to long format
df_long = df.melt(id_vars=["Match Day"], var_name="Participant", value_name="Points").dropna()

# 3. Custom function to handle initials and prevent duplicates
def get_unique_initials(name):
    if name == "Andrew Freeman": return "AnF"
    if name == "Andre Fonseca": return "AdF"
    if name == "Gustavo Bortolazzi": return "GuB"
    if name == "Gabriel Bueno": return "GaB"
    parts = name.split()
    return "".join([p[0].upper() for p in parts if p])

df_long['Initials'] = df_long['Participant'].apply(get_unique_initials)

# 4. Calculate ranks per match day (highest score = Rank 1)
df_long['Rank'] = df_long.groupby('Match Day')['Points'].rank(ascending=False, method='min').astype(int)

# 5. Pivot data for easy plotting
df_ranks = df_long.pivot(index='Match Day', columns='Initials', values='Rank')

# 6. Build the Bump Chart
plt.figure(figsize=(16, 10), dpi=300) # High resolution for GitHub

for col in df_ranks.columns:
    plt.plot(df_ranks.index, df_ranks[col], marker='o', alpha=0.6, linewidth=2, label=col)

# Format axes
plt.gca().invert_yaxis()  # Puts 1st place at the top
plt.yticks(range(1, 36, 2))
plt.xticks(df_ranks.index)

# Labels & Styling
plt.title("Leaderboard Rank Evolution (1st Place at Top)", fontsize=18, fontweight='bold', pad=15)
plt.xlabel("Match Day", fontsize=14, labelpad=10)
plt.ylabel("Rank Place", fontsize=14, labelpad=10)
plt.grid(True, linestyle="--", alpha=0.5)

# Place legend cleanly on the right side
plt.legend(bbox_to_anchor=(1.02, 1), loc='upper left', ncol=2, fontsize=10, frameon=True)
plt.tight_layout()

# 7. Save as an image file
plt.savefig("leaderboard_rank_evolution.png", bbox_inches='tight')
print("Image saved successfully as leaderboard_rank_evolution.png")

